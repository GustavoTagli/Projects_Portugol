programa {
	funcao inicio() {
	    //FACA ENQUANTO - EXERCÕCIO 1//
	    //FaÁa um programa que mostre uma contagem na tela de 233 a 456, sÛ que contando
	    //de 3 em 3 quando estiver entre 300 e 400 e de 5 em 5 quando n„o estiver
	    
	    inteiro x = 233

	    faca{
	        escreva(x, " ")
	        
	        se(x >= 300 e x <= 400) x += 3
	        senao x += 5
	        
	    }enquanto(x <= 456)
	}
}
